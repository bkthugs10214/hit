# ─── Precog Baseline Miner — Environment Template ─────────────────────────────
# Copy this file to <precog-repo>/.env.miner and fill in your wallet details.
# Lines beginning with # are comments and are ignored.

# ── Network ──────────────────────────────────────────────────────────────────
# Options: testnet | finney (mainnet) | localnet
NETWORK=testnet

# ── Wallet ───────────────────────────────────────────────────────────────────
# Name of your coldkey (created with: btcli wallet new_coldkey --wallet.name miner)
COLDKEY=miner
# Name of your hotkey (created with: btcli wallet new_hotkey --wallet.name miner --wallet.hotkey default)
MINER_HOTKEY=default

# ── Miner identity ───────────────────────────────────────────────────────────
MINER_NAME=baseline-miner
MINER_PORT=8092

# ── Forward function ─────────────────────────────────────────────────────────
# Name of the Python module in precog/miners/ to use as the forward function.
# Set to "baseline_miner" after running deploy.sh.
FORWARD_FUNCTION=baseline_miner

# ── Performance ──────────────────────────────────────────────────────────────
# Response timeout in seconds (validators default to ~20 s)
TIMEOUT=16
# Minimum stake (in TAO) a validator must have to send requests to this miner
VPERMIT_TAO_LIMIT=2

# ── Logging ──────────────────────────────────────────────────────────────────
LOGGING_LEVEL=info

# ── Local subtensor (only needed for localnet development) ───────────────────
LOCAL_SUBTENSOR=ws://127.0.0.1:9945

# ── Coin Metrics API key ─────────────────────────────────────────────────────
# Optional: only required if you want the CoinMetrics fallback data path.
# Free-tier keys available at https://coinmetrics.io
CM_API_KEY=

# ── Forecast tuning (optional, override defaults in config.py) ───────────────
# Shrinkage factor applied to momentum drift (0.0 = persistence, 1.0 = full momentum)
POINT_SHRINKAGE=0.10
# Multiplier on realized-vol half-width (increase for wider intervals)
INTERVAL_MULTIPLIER=1.0
# Directory for forecast log (defaults to ~/.precog_baseline)
PRECOG_BASELINE_LOG_DIR=
